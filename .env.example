APP_NAME="English Learning Platform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=english_platform
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=true

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Tap Payment Gateway
TAP_SECRET_KEY=
TAP_PUBLIC_KEY=
TAP_WEBHOOK_URL="${APP_URL}/api/tap/webhook"

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_URL="${APP_URL}/api/telegram/webhook"
TELEGRAM_WEBHOOK_SECRET=

# Google Cloud TTS
GOOGLE_CLOUD_PROJECT_ID=
# Path to your Google service account JSON file (absolute path or relative to project root)
GOOGLE_APPLICATION_CREDENTIALS=

# AWS (alternative to Google)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Application Settings
POINTS_PER_LESSON=10
POINTS_PER_QUIZ=30
POINTS_PER_DAILY_QUESTION=5
POINTS_PER_PRONUNCIATION=10
REFERRAL_DISCOUNT_PERCENTAGE=10
DAILY_QUESTION_TIME=09:00
SEND_DAILY_QUESTIONS_ALTERNATE_DAYS=true

# VdoCipher Video Hosting (DRM)
VDOCIPHER_API_SECRET=

# Realtime Pronunciation Streaming
PRONUNCIATION_STREAM_ENABLED=false
PRONUNCIATION_STREAM_WS_URL=ws://127.0.0.1:8787/ws
PRONUNCIATION_STREAM_CHUNK_MS=1000

# Pronunciation Upload Mode (recommended for iPhone/Android/Desktop)
PRONUNCIATION_UPLOAD_ENABLED=true
PRONUNCIATION_UPLOAD_PYTHON_BIN=python3
PRONUNCIATION_UPLOAD_GATEWAY_WS_URL=ws://127.0.0.1:8787/ws
PRONUNCIATION_UPLOAD_TIMEOUT_SECONDS=90

# Local Writing AI
WRITING_AI_ENABLED=false
LANGUAGETOOL_URL=http://127.0.0.1:8010
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
WRITING_AI_TIMEOUT_SECONDS=45

# Local Speaking AI
SPEAKING_AI_ENABLED=false
SPEAKING_AI_OLLAMA_URL=http://127.0.0.1:11434
SPEAKING_AI_OLLAMA_MODEL=qwen2.5:7b
SPEAKING_AI_TIMEOUT_SECONDS=30
SPEAKING_AI_SCORE_BLEND_RATIO=0.35
